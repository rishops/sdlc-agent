# Copy to .env and fill in. .env is gitignored. NEVER commit real secrets.

# --- Vertex AI (selected for local dev) ------------------------------------
GOOGLE_GENAI_USE_VERTEXAI=True
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global

# --- Per-role models (optional overrides; defaults are gemini-3-flash-preview)
# Upgrade reasoning-heavy roles if desired, e.g.:
# MODEL_PLANNER=gemini-3-pro-preview

# --- GitHub access ---------------------------------------------------------
# Fine-grained PAT scoped to your throwaway TEST repo only.
GITHUB_TOKEN=github_pat_xxx
TARGET_REPO=owner/test-repo
TRIGGER_LABEL=agent:build
# Shared secret for verifying the GitHub webhook HMAC (event-driven trigger).
GITHUB_WEBHOOK_SECRET=change-me

# --- Sandbox backend -------------------------------------------------------
# host = run git/build/test locally (offline, used for P1 verification)
# agent_engine = managed GCP sandbox (set the resource vars below; used at deploy)
SANDBOX_BACKEND=host
# SANDBOX_AGENT_ENGINE_RESOURCE=
# SANDBOX_RESOURCE_NAME=
# HOST_WORKDIR_ROOT=

# --- Run bounds ------------------------------------------------------------
MAX_PLAN_ITERATIONS=2
MAX_LOOP_ITERATIONS=4
# Per-turn generation cap (stops a degenerate model repetition loop).
MAX_OUTPUT_TOKENS=8192
DEFAULT_TEMPERATURE=0.5
MAX_RUN_WALL_SECONDS=1800

# --- Status posting --------------------------------------------------------
# Set to false to disable posting comments/labels to GitHub (dry runs).
POST_STATUS=true
